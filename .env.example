PORT=3000
# Opcional: fuso para “saldo acumulado até hoje” (default America/Sao_Paulo)
# APP_TIMEZONE=America/Sao_Paulo

# ── Supabase ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Segurança ─────────────────────────────────────────────────────────────
ADMIN_SECRET=defina-uma-senha-admin-segura
N8N_WEBHOOK_SECRET=defina-um-segredo-longo-para-o-n8n

# ── URLs ──────────────────────────────────────────────────────────────────
APP_URL=https://financezap.thesilasstudio.com.br
N8N_SEND_WHATSAPP_URL=https://seu-n8n.com/webhook/financezap-send-whatsapp

# ── IA (Gemini) ───────────────────────────────────────────────────────────
GEMINI_API_KEY=sua-chave-gemini

# ── Email ─────────────────────────────────────────────────────────────────
# Provider: "gmail" (padrão) ou "resend"
EMAIL_PROVIDER=gmail
EMAIL_FROM=FinanceZap <seuemail@gmail.com>

# Gmail SMTP (ative Verificação 2 etapas + crie Senha de App)
GMAIL_USER=seuemail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Resend (alternativa) — só precisa se EMAIL_PROVIDER=resend
# RESEND_API_KEY=sua-chave-resend

# ── Preço do produto ──────────────────────────────────────────────────────
PRICE=27.90

# Proxy (Caddy/Nginx/EasyPanel): encaminhe para o Node pelo menos um destes prefixos:
#   /insights/api   e/ou   /api   (opcional: /health na raiz para probe)
#
# Nginx — ordem importa: blocos location /api e /insights/api devem vir ANTES de
#   location / { try_files ... index.html }  senão o SPA devolve HTML e o app acusa
#   "API inacessível (só HTML)".
#
# Caddy (exemplo): handle /api* e handle /insights/api* com reverse_proxy para o Node
# antes do file_server do frontend.
#
# Frontend em host diferente do Node: nas páginas, antes de auth.js, defina
#   window.__FINANCEZAP_API_ORIGIN__ = "https://seu-node";  (requer CORS no Node se cross-origin)
# ou <meta name="financezap-api-origin" content="https://seu-node">
#
# Se o navegador e o Node forem domínios diferentes, defina também (URL do site que acessa a API):
# FINANCEZAP_CORS_ORIGIN=https://seu-frontend.com.br
#
# Webhook n8n: POST .../insights/api/webhook/n8n  ou  .../api/webhook/n8n

# Opcional — import DADOS MENSAIS (planilha Out→Set = ano fiscal):
# IMPORT_DADOS_ANO_OUT_A_DEZ=2025
# IMPORT_DADOS_ANO_JAN_A_SET=2026
# Ou um único ano (planilha começando em Janeiro):
# IMPORT_DADOS_ANO=2026
# IMPORT_SKIP_DADOS_MENSAIS=1
