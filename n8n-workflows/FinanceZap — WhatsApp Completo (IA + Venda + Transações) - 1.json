    {
      "parameters": {
        "jsCode": "// Extrai dados do webhook da Evolution API (somente texto)\nconst raw = $input.first().json || {};\nconst body = raw.body || raw;\n\nif (body?.data?.key?.fromMe === true || body?.data?.messages?.[0]?.key?.fromMe === true) {\n  return [{ json: { action: 'skip', reason: 'fromMe' } }];\n}\n\nconst event = body?.event || '';\nif (!event.includes('messages')) {\n  return [{ json: { action: 'skip', reason: 'not_message' } }];\n}\n\nconst keyObj = body?.data?.key || body?.data?.messages?.[0]?.key || {};\nconst msgObj = body?.data?.message || body?.data?.messages?.[0]?.message || {};\nconst remoteJid = keyObj.remoteJid || '';\nif (!remoteJid || remoteJid.includes('@g.us')) {\n  return [{ json: { action: 'skip', reason: 'group_or_no_jid' } }];\n}\n\nlet phone = String(remoteJid).replace(/@s\\.whatsapp\\.net/, '').replace(/[^0-9]/g, '');\nif (!phone) {\n  return [{ json: { action: 'skip', reason: 'no_phone' } }];\n}\nif (phone.length === 10 || phone.length === 11) {\n  phone = '55' + phone;\n}\n\nconst pushName = body?.data?.pushName || body?.data?.messages?.[0]?.pushName || 'amigo';\nconst text = (\n  msgObj.conversation ||\n  msgObj.extendedTextMessage?.text ||\n  ''\n).trim();\n\nif (!text) {\n  return [{ json: { action: 'skip', reason: 'no_text_or_media' } }];\n}\n\nreturn [{ json: { action: 'process', phone, pushName, text } }];"
      },
