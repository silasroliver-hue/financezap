      "parameters": {
        "jsCode": "// Prepara dados da imagem para enviar ao backend\nconst parseMensagem = $('Parsear Mensagem').first().json;\nconst downloadResp = $input.first().json;\n\nconst base64 = downloadResp.base64 || downloadResp.data || null;\nconst mimeType = downloadResp.mediaType || 'image/jpeg';\n\nif (!base64) {\n  return [{ json: { action: 'send', phone: parseMensagem.phone, msg: '📸 Recebi a imagem, mas não consegui processá-la. Tente uma foto mais nítida ou use o *menu*.' } }];\n}\n\nreturn [{ json: {\n  phone: parseMensagem.phone,\n  pushName: parseMensagem.pushName,\n  imageBase64: base64,\n  mimeType: mimeType,\n  caption: parseMensagem.text || ''\n} }];\n"
