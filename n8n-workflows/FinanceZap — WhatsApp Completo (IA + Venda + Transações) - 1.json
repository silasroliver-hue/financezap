    {
      "parameters": {
        "jsCode": "// ── Extrai dados do webhook da Evolution API (com suporte a áudio e imagem) ──\nconst raw = $input.first().json;\nconst body = raw.body || raw;\n\nif (body?.data?.key?.fromMe === true) {\n  return [{ json: { action: 'skip', reason: 'fromMe' } }];\n}\n\nconst event = body?.event || '';\nif (!event.includes('messages')) {\n  return [{ json: { action: 'skip', reason: 'not_message' } }];\n}\n\nconst remoteJid = body?.data?.key?.remoteJid || '';\nif (remoteJid.includes('@g.us')) {\n  return [{ json: { action: 'skip', reason: 'group' } }];\n}\n\nconst phone = remoteJid.replace(/@s\\.whatsapp\\.net/, '').replace(/[^0-9]/g, '');\nconst msgData = body?.data?.message || {};\nconst pushName = body?.data?.pushName || 'amigo';\n\n// Detecta tipo de mídia\nconst isAudio = !!(msgData.audioMessage || msgData.pttMessage);\nconst isImage = !!(msgData.imageMessage);\nconst isText = !!(msgData.conversation || msgData.extendedTextMessage);\n\nconst text = (\n  msgData.conversation ||\n  msgData.extendedTextMessage?.text ||\n  msgData.imageMessage?.caption ||\n  ''\n).trim();\n\nif (!phone) {\n  return [{ json: { action: 'skip', reason: 'no_phone' } }];\n}\n\n// Áudio sem texto → processa como mídia\nif (isAudio) {\n  const messageObject = body?.data?.message || {};\n  return [{ json: { action: 'audio', phone, pushName, messageObject: JSON.stringify(messageObject), fullData: JSON.stringify(body?.data || {}) } }];\n}\n\n// Imagem → processa como mídia (com caption opcional)\nif (isImage) {\n  const messageObject = body?.data?.message || {};\n  const caption = msgData.imageMessage?.caption || '';\n  return [{ json: { action: 'image', phone, pushName, text: caption, messageObject: JSON.stringify(messageObject), fullData: JSON.stringify(body?.data || {}) } }];\n}\n\n// Texto\nif (!text) {\n  return [{ json: { action: 'skip', reason: 'no_text' } }];\n}\n\nreturn [{ json: { action: 'process', phone, pushName, text } }];\n"
      },
