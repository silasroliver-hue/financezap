    {
      "parameters": {
        "jsCode": "// Roteia resposta do backend de texto\nconst resp = $input.first().json;\nconst parsed = $('Parsear Mensagem').first().json;\n\nif ($input.first().json.error && !resp.type) {\n  return [{ json: { action: 'send', phone: parsed.phone, msg: 'Servico temporariamente indisponivel. Tente novamente em instantes.' } }];\n}\n\nconst type = resp.type || 'user';\n\nif (type === 'sales') {\n  return [{ json: { action: 'sales', phone: parsed.phone, text: parsed.text, pushName: parsed.pushName } }];\n}\n\nconst reply = resp.reply || 'Ola! Como posso ajudar?';\nreturn [{ json: { action: 'send', phone: parsed.phone, msg: reply } }];\n"
      },
