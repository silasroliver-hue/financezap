    {
      "parameters": {
        "jsCode": "// Prepara dados do áudio para enviar ao backend\nconst parseMensagem = $('Parsear Mensagem').first().json;\nconst downloadResp = $input.first().json;\n\nconst base64 = downloadResp.base64 || downloadResp.data || null;\nconst mimeType = downloadResp.mediaType || 'audio/ogg; codecs=opus';\n\nif (!base64) {\n  return [{ json: { action: 'send', phone: parseMensagem.phone, msg: '🎤 Recebi seu áudio, mas não consegui processá-lo. Tente novamente ou use o *menu* para lançar manualmente.' } }];\n}\n\nreturn [{ json: {\n  phone: parseMensagem.phone,\n  pushName: parseMensagem.pushName,\n  audioBase64: base64,\n  mimeType: mimeType\n} }];\n"
      },
