      "parameters": {
        "jsCode": "// Formata resposta do agente de vendas\nconst aiResp = $input.first()?.json || {};\nconst parsed = $('Processar Resposta Chat').first()?.json || {};\n\nlet reply = aiResp.reply ||\n  'Ola! Conheca o FinanceZap, controle financeiro pelo WhatsApp. Digite quero saber mais para ver como funciona!';\n\nreply = String(reply).replace(/\\r/g, '').trim();\n\nconst phone = String(parsed.phone || '').replace(/\\D/g, '');\nif (!phone) throw new Error('Telefone invalido.');\n\nreturn [{ json: { phone, msg: reply } }];\n"
