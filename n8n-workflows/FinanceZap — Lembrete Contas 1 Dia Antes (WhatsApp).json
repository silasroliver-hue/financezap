    {
      "parameters": {
        "jsCode": "function toBRL(v) {\n  const n = Number(v || 0);\n  return n.toLocaleString('pt-BR', { style: 'currency', currency: 'BRL' });\n}\n\nfunction toBRDate(isoDate) {\n  if (!isoDate || typeof isoDate !== 'string') return '';\n  const [y, m, d] = isoDate.split('-');\n  if (!y || !m || !d) return isoDate;\n  return `${d}/${m}/${y}`;\n}\n\nconst row = $input.first().json || {};\nlet phone = String(row.whatsapp_phone || '').replace(/\\D/g, '');\nif (!phone || phone.length < 8) {\n  return [];\n}\n\n// Normaliza para BR com DDI 55 (Evolution API funciona melhor nesse formato)\nif (phone.length === 10 || phone.length === 11) {\n  phone = `55${phone}`;\n}\nif (phone.startsWith('0')) {\n  phone = phone.replace(/^0+/, '');\n  if (phone.length === 10 || phone.length === 11) phone = `55${phone}`;\n}\n\nconst fullName = String(row.full_name || '').trim();\nconst firstName = fullName ? fullName.split(/\\s+/)[0] : 'amigo';\nconst billName = String(row.bill_name || 'Conta');\nconst amount = toBRL(row.bill_amount);\nconst category = String(row.bill_category || 'Contas do mês');\nconst dueDate = toBRDate(String(row.due_date || ''));\n\nconst msg = `Ei, ${firstName}! 🛒 Espero que tudo bem com vc, estou aqui apenas para te avisar que tem uma conta sua vencendo! 😊\\n\\n🧾 Resumo:\\n\\n🛒 Descrição: ${billName}\\n\\n💰 Valor: ${amount}\\n\\n🛍️ Categoria: ${category}\\n\\n📅 Data: ${dueDate}\\n\\n📊 Para visualizar mais detalhes e relatórios, acesse a plataforma em\\n\\nhttps://financezap.thesilasstudio.com.br/insights/index.html\\n\\nSe precisar de algo a mais é só me chamar! 😄`;\n\nreturn [{\n  json: {\n    phone,\n    msg,\n    bill_id: row.bill_id || null,\n    user_id: row.user_id || null,\n    due_date: row.due_date || null\n  }\n}];"
      },
