    {
      "parameters": {
        "jsCode": "const payload = $input.first().json || {};\nconst items = Array.isArray(payload.items) ? payload.items : [];\n\nif (!items.length) {\n  return [];\n}\n\nreturn items.map((it) => ({ json: it }));"
